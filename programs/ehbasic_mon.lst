002828r 2               
002828r 2               AA_end_basic
002828r 2               
002828r 1               
002828r 1               CR  = $0D
002828r 1               LF  = $0A
002828r 1               
002828r 1               ; put the IRQ and NMI code in RAM so that it can be changed
002828r 1               
002828r 1               IRQ_vec	= VEC_SV+2		; IRQ code vector
002828r 1               NMI_vec	= IRQ_vec+$0A	; NMI code vector
002828r 1               
002828r 1               ; reset vector points here
002828r 1               
002828r 1               RES_vec
002828r 1  D8           	CLD			; clear decimal mode
002829r 1  A2 FF        	LDX	#$FF		; empty stack
00282Br 1  9A           	TXS			; set the stack
00282Cr 1               
00282Cr 1               ; set up vectors and interrupt code, copy them to page 2
00282Cr 1               
00282Cr 1  A0 1C        	LDY	#END_CODE-LAB_vec	; set index/count
00282Er 1               LAB_stlp
00282Er 1  B9 rr rr     	LDA	LAB_vec-1,Y	; get byte from interrupt code
002831r 1  99 04 03     	STA	VEC_IN-1,Y	; save to RAM
002834r 1  88           	DEY			; decrement index/count
002835r 1  D0 F7        	BNE	LAB_stlp	; loop if more to do
002837r 1               
002837r 1               ; now do the signon message, Y = $00 here
002837r 1               
002837r 1               LAB_signon
002837r 1  B9 rr rr     	LDA	LAB_mess,Y	; get byte from sign on message
00283Ar 1  F0 06        	BEQ	LAB_nokey	; exit loop if done
00283Cr 1               
00283Cr 1  20 rr rr     	JSR	V_OUTP		; output character
00283Fr 1  C8           	INY			; increment index
002840r 1  D0 F5        	BNE	LAB_signon	; loop, branch always
002842r 1               
002842r 1               LAB_nokey
002842r 1  20 rr rr     	JSR	V_INPT		; call scan input device
002845r 1  90 FB        	BCC	LAB_nokey	; loop if no key
002847r 1               
002847r 1  29 DF        	AND	#$DF		; mask to upper case
002849r 1  C9 57        	CMP	#'W'		; compare with [W]arm start
00284Br 1  F0 07        	BEQ	LAB_dowarm	; branch if [W]arm start
00284Dr 1               
00284Dr 1  C9 43        	CMP	#'C'		; compare with [C]old start
00284Fr 1  D0 D7        	BNE	RES_vec		; loop if not [C]old start
002851r 1               
002851r 1  4C rr rr     	JMP	LAB_COLD	; do EhBASIC cold start
002854r 1               
002854r 1               LAB_dowarm
002854r 1  4C 00 00     	JMP	LAB_WARM	; do EhBASIC warm start
002857r 1               
002857r 1               ; byte out to simpleCPU terminal
002857r 1               
002857r 1               ACIAout
002857r 1  C9 0A        	CMP	#LF		; ignore line feed
002859r 1  F0 03        	BEQ	@ignore
00285Br 1  8D 01 FE     	STA	$FE01		; write character to simulator output port
00285Er 1               @ignore
00285Er 1  60           	RTS
00285Fr 1               
00285Fr 1               ; byte in from simpleCPU terminal
00285Fr 1               
00285Fr 1               ACIAin
00285Fr 1  AD 02 FE     	LDA	$FE02		; check input status
002862r 1  10 07        	BPL	LAB_nobyw	; branch if no byte waiting (bit 7 clear)
002864r 1               
002864r 1  AD 03 FE     	LDA	$FE03		; read input byte
002867r 1  29 7F        	AND	#$7F		; clear high bit
002869r 1  38           	SEC			; flag byte received
00286Ar 1  60           	RTS
00286Br 1               
00286Br 1               LAB_nobyw
00286Br 1  18           	CLC			; flag no byte received
00286Cr 1  60           	RTS
00286Dr 1               
00286Dr 1               ; stub LOAD — just print error
00286Dr 1               
00286Dr 1               LOAD
00286Dr 1  A9 3F        	LDA	#'?'
00286Fr 1  20 rr rr     	JSR	ACIAout
002872r 1  60           	RTS
002873r 1               
002873r 1               ; stub SAVE — just print error
002873r 1               
002873r 1               SAVE
002873r 1  A9 3F        	LDA	#'?'
002875r 1  20 rr rr     	JSR	ACIAout
002878r 1  60           	RTS
002879r 1               
002879r 1               ; vector tables
002879r 1               
002879r 1               LAB_vec
002879r 1  rr rr        	.word	ACIAin		; byte in
00287Br 1  rr rr        	.word	ACIAout		; byte out
00287Dr 1  rr rr        	.word	LOAD		; load vector for EhBASIC
00287Fr 1  rr rr        	.word	SAVE		; save vector for EhBASIC
002881r 1               
002881r 1               ; EhBASIC IRQ support
002881r 1               
002881r 1               IRQ_CODE
002881r 1  48           	PHA			; save A
002882r 1  A5 DF        	LDA	IrqBase		; get the IRQ flag byte
002884r 1  4A           	LSR			; shift the set b7 to b6, and on down ...
002885r 1  05 DF        	ORA	IrqBase		; OR the original back in
002887r 1  85 DF        	STA	IrqBase		; save the new IRQ flag byte
002889r 1  68           	PLA			; restore A
00288Ar 1  40           	RTI
00288Br 1               
00288Br 1               ; EhBASIC NMI support
00288Br 1               
00288Br 1               NMI_CODE
00288Br 1  48           	PHA			; save A
00288Cr 1  A5 DC        	LDA	NmiBase		; get the NMI flag byte
00288Er 1  4A           	LSR			; shift the set b7 to b6, and on down ...
00288Fr 1  05 DC        	ORA	NmiBase		; OR the original back in
002891r 1  85 DC        	STA	NmiBase		; save the new NMI flag byte
002893r 1  68           	PLA			; restore A
002894r 1  40           	RTI
002895r 1               
002895r 1               END_CODE
002895r 1               
002895r 1               LAB_mess
002895r 1  0D 0A 36 35  	.byte	$0D,$0A,"6502 EhBASIC [C]old/[W]arm ?",$00
002899r 1  30 32 20 45  
00289Dr 1  68 42 41 53  
0028B4r 1               
0028B4r 1               ; system vectors
0028B4r 1               
0028B4r 1               	.segment "VECTORS"
000000r 1               
000000r 1  17 03        	.word	NMI_vec		; NMI vector
000002r 1  rr rr        	.word	RES_vec		; RESET vector
000004r 1  0D 03        	.word	IRQ_vec		; IRQ vector
000004r 1               
