000000r 1               ; minimal monitor for EhBASIC on simpleCPU simulator
000000r 1               ; Derived from EhBASIC
000000r 1               ;
000000r 1               ; I/O addresses match simpleCPU memory map:
000000r 1               ;   $FE01 = character output
000000r 1               ;   $FE02 = input status (bit 7 set = data ready)
000000r 1               ;   $FE03 = input data (bit 7 set on returned byte)
000000r 1               
000000r 1               	.include "ehbasic.asm"
