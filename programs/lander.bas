10 PRINT "*** LUNAR LANDER ***"
20 PRINT "LAND WITH VELOCITY <= 5"
30 PRINT "MAX BURN PER TURN = 30"
40 PRINT
50 LET A=1000
60 LET V=0
70 LET F=150
80 LET T=0
100 PRINT "TURN ";T;": ALT=";A;" VEL=";V;" FUEL=";F
110 PRINT "BURN";
120 INPUT B
130 IF B<0 THEN 110
140 IF B>30 THEN 110
150 IF B>F THEN 110
160 LET F=F-B
170 LET V=V+5-B
180 LET A=A-V
190 LET T=T+1
200 IF A<=0 THEN 300
210 GOTO 100
300 PRINT
310 PRINT "TOUCHDOWN AT VELOCITY ";V
320 IF V<=5 THEN 400
330 PRINT "*** CRASH ***"
340 PRINT "MISSION FAILED"
350 END
400 PRINT "*** SAFE LANDING ***"
410 PRINT "FUEL REMAINING: ";F
420 PRINT "TURNS: ";T
430 END
RUN
