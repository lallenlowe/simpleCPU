100 REM Bouncing ball using ROM graphics primitives
110 REM Addresses: CLG=59598 PLOT=59623 LINE=59675 FILL=59802
120 CG=59598:PL=59623:LN=59675:FL=59802
130 REM Graphics params at zero page $E0-$E5
140 REM 224=color 225=x1 226=y1 227=x2 228=y2 229=radius
200 REM Ball state
210 X=32:Y=24:DX=1:DY=1:R=4:C=10
220 REM Enable graphics mode 1
230 POKE 65028,1
300 REM Clear and draw
310 POKE 224,0:CALL CG
320 POKE 224,C:POKE 225,X:POKE 226,Y:POKE 229,R
330 CALL FL
400 REM Move
410 X=X+DX:Y=Y+DY
420 IF X<R THEN X=R:DX=-DX:C=C+1
430 IF X>63-R THEN X=63-R:DX=-DX:C=C+1
440 IF Y<R THEN Y=R:DY=-DY:C=C+1
450 IF Y>47-R THEN Y=47-R:DY=-DY:C=C+1
460 IF C>255 THEN C=1
500 GOTO 300
